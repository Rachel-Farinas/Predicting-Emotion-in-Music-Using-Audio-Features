target_key <- "G1_Rhythmic_valence"
top_rf_model <- rf_models[[target_key]]
group_name <- sub("_(valence|energy)$", "", target_key)
train_data <- groups[[group_name]]
# ── STEP 2: Pick features ────────────────────────────────────────────────────
imp <- as.data.frame(randomForest::importance(top_rf_model))
features_to_plot <- rownames(imp)[order(imp[,1], decreasing = TRUE)][1:2]
# ── STEP 3: The "Fail-Safe" Loop ─────────────────────────────────────────────
for (feat in features_to_plot) {
cat("Processing feature:", feat, "\n")
# We use pdp::partial and explicitly define the wrapper
# This bypasses the purrr conflict entirely
pd_data <- pdp::partial(
top_rf_model,
pred.var = feat,
train = train_data,
# This force-feeds the prediction method to R
pred.fun = function(object, newdata) predict(object, newdata)
)
# Plotting using standard ggplot2 to avoid autoplot bugs
p_pd <- ggplot(pd_data, aes_string(x = feat, y = "yhat")) +
geom_line(color = "#4e9af1", linewidth = 1.2) +
geom_point(color = "#4e9af1") +
ylim(0, 1) +
labs(title = paste("PDP:", feat, "on Valence"),
subtitle = paste("Genre Group:", group_name),
x = feat, y = "Partial Dependence (Predicted Valence)") +
theme_bw()
ggsave(paste0("plots/PDP_FIXED_", target_key, "_", feat, ".png"), p_pd, width = 8, height = 5)
}
