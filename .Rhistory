print(as.data.frame(master %>%
filter(Model == "StackedEnsemble") %>%
select(Group, Target, RMSE, R2) %>%
arrange(Group, Target)))
cat("\nKey findings:\n")
cat("- Stacked Ensemble blends LR + EN + KNN + RF + XGBoost via a linear meta-learner\n")
cat("- KNN+PCA uses prcomp() retaining 95% variance before fitting KNN\n")
cat("- Energy is easier to predict than Valence in every group\n")
cat("- G2 Classical has the best energy R2 (0.91)\n")
cat("- G2 Classical has the hardest valence to predict (R2 = 0.58)\n")
cat("- Kruskal-Wallis H(valence) = 3242.8, p < 0.001 (groups are different)\n")
cat("- Kruskal-Wallis H(energy)  = 5053.4, p < 0.001 (groups are different)\n")
cat("- SHAP: danceability is the most group-divergent feature\n")
cat("- SHAP: loudness is the most consistent feature across groups\n")
cat("\nAll plots saved to the 'plots/' folder:\n")
cat(list.files("plots"), sep = "\n")
cat("\n DONE!\n")
# =============================================================================
#  LINEAR MODELS SECTION
#  Different predictor sets for Energy & Valence + ElasticNet hypertuning
#  Across all three genre groups (G1 Rhythmic, G2 Classical, G3 Hard Rock)
# =============================================================================
cat("\n\n============================================================\n")
cat(" LINEAR MODELS — PREDICTOR COMPARISON + ELASTICNET TUNING\n")
cat("============================================================\n\n")
# ── Predictor sets ────────────────────────────────────────────────────────────
# For ENERGY: loudness is known to dominate, but we test whether adding
# rhythm or acoustic features meaningfully improves fit.
# For VALENCE: notoriously harder to predict — we test several theories.
energy_predictor_sets <- list(
"M1: Loudness only"                          = c("loudness"),
"M2: Loudness + Acousticness + Instrumentalness" = c("loudness", "acousticness", "instrumentalness"),
"M3: Tempo + Danceability + Liveness"        = c("tempo", "danceability", "liveness"),
"M4: All audio features"                     = c("loudness", "acousticness", "instrumentalness",
"tempo", "danceability", "liveness",
"speechiness", "valence"),
"M5: Audio + Popularity + Duration"          = c("loudness", "acousticness", "instrumentalness",
"tempo", "danceability", "liveness",
"speechiness", "valence",
"popularity", "duration_ms")
)
valence_predictor_sets <- list(
"M1: Danceability only"                      = c("danceability"),
"M2: Danceability + Energy"                  = c("danceability", "energy"),
"M3: Danceability + Energy + Acousticness"   = c("danceability", "energy", "acousticness"),
"M4: All audio features"                     = c("danceability", "energy", "loudness",
"acousticness", "instrumentalness",
"liveness", "speechiness", "tempo"),
"M5: Audio + Popularity + Duration"          = c("danceability", "energy", "loudness",
"acousticness", "instrumentalness",
"liveness", "speechiness", "tempo",
"popularity", "duration_ms")
)
# ── Storage ───────────────────────────────────────────────────────────────────
lm_results_all <- list()
en_results_all <- list()
en_models_all  <- list()
# ElasticNet alpha grid: 0 = Ridge, 1 = Lasso, everything in between = ElasticNet
alpha_grid <- seq(0, 1, by = 0.1)
# =============================================================================
#  MAIN LOOP: group x target x predictor set
# =============================================================================
for (gname in names(groups)) {
gdata <- groups[[gname]]
for (tgt in targets) {
pred_sets <- if (tgt == "energy") energy_predictor_sets else valence_predictor_sets
cat("\n>>> Group:", gname, "| Target:", tgt, "\n")
# ── OLS: one model per predictor set ──────────────────────────────────────
cat("  OLS across", length(pred_sets), "predictor sets...\n")
for (mname in names(pred_sets)) {
preds       <- pred_sets[[mname]]
df_slice    <- gdata %>% select(all_of(c(tgt, preds))) %>% drop_na()
idx         <- createDataPartition(df_slice[[tgt]], p = 0.75, list = FALSE)
train_ols   <- df_slice[ idx, ]
test_ols    <- df_slice[-idx, ]
fit_ols  <- lm(as.formula(paste(tgt, "~", paste(preds, collapse = " + "))), data = train_ols)
pred_ols <- pmax(0, pmin(1, predict(fit_ols, test_ols)))
m        <- get_metrics(pred_ols, test_ols[[tgt]])
key      <- paste(gname, tgt, mname, sep = " | ")
lm_results_all[[key]] <- data.frame(
Group        = gname,
Target       = tgt,
Model        = "OLS",
PredictorSet = mname,
RMSE         = m$RMSE,
MAE          = m$MAE,
R2           = m$R2,
N_predictors = length(preds),
stringsAsFactors = FALSE
)
cat("    OLS", mname, "-> R2 =", m$R2, "| RMSE =", m$RMSE, "\n")
}
# ── ElasticNet: tune alpha AND lambda simultaneously ───────────────────────
# Use M4 (all audio features) as the feature set for ElasticNet
cat("  ElasticNet — tuning alpha in {0, 0.1, ..., 1} via 5-fold CV...\n")
full_preds <- if (tgt == "energy") energy_predictor_sets[["M4: All audio features"]] else
valence_predictor_sets[["M4: All audio features"]]
df_en    <- gdata %>% select(all_of(c(tgt, full_preds))) %>% drop_na()
idx_en   <- createDataPartition(df_en[[tgt]], p = 0.75, list = FALSE)
train_en <- df_en[ idx_en, ]
test_en  <- df_en[-idx_en, ]
X_train <- as.matrix(train_en[, full_preds])
X_test  <- as.matrix(test_en[,  full_preds])
y_train <- train_en[[tgt]]
y_test  <- test_en[[tgt]]
# Scale on train, apply to test
col_means <- colMeans(X_train)
col_sds   <- apply(X_train, 2, sd);  col_sds[col_sds == 0] <- 1
X_train_sc <- sweep(sweep(X_train, 2, col_means, "-"), 2, col_sds, "/")
X_test_sc  <- sweep(sweep(X_test,  2, col_means, "-"), 2, col_sds, "/")
for (a in alpha_grid) {
a_label <- paste0("alpha=", round(a, 1))
# cv.glmnet finds the best lambda for this alpha automatically
en_cv <- cv.glmnet(x = X_train_sc, y = y_train,
alpha = a, nfolds = 5, standardize = FALSE)
for (lam_choice in c("lambda.min", "lambda.1se")) {
en_pred <- pmax(0, pmin(1, predict(en_cv, X_test_sc, s = lam_choice)[, 1]))
m       <- get_metrics(en_pred, y_test)
key     <- paste(gname, tgt, a_label, lam_choice, sep = " | ")
en_results_all[[key]] <- data.frame(
Group       = gname,
Target      = tgt,
Model       = "ElasticNet",
Alpha       = a,
Lambda_rule = lam_choice,
Best_lambda = round(en_cv[[lam_choice]], 6),
RMSE        = m$RMSE,
MAE         = m$MAE,
R2          = m$R2,
stringsAsFactors = FALSE
)
en_models_all[[key]] <- en_cv
}
cat("    EN", a_label, "| lambda.min -> R2 =",
en_results_all[[paste(gname, tgt, a_label, "lambda.min", sep = " | ")]]$R2, "\n")
}
}
}
# =============================================================================
#  COMPILE & SAVE RESULTS
# =============================================================================
lm_master <- bind_rows(lm_results_all)
en_master <- bind_rows(en_results_all)
cat("\n\n--- OLS Results ---\n")
print(as.data.frame(lm_master %>% arrange(Group, Target, PredictorSet)))
cat("\n\n--- ElasticNet Results (lambda.min only) ---\n")
print(as.data.frame(en_master %>% filter(Lambda_rule == "lambda.min") %>% arrange(Group, Target, Alpha)))
write_csv(lm_master, "ols_predictor_comparison.csv")
write_csv(en_master, "elasticnet_alpha_tuning.csv")
cat("\nSaved: ols_predictor_comparison.csv and elasticnet_alpha_tuning.csv\n")
# =============================================================================
#  PLOTS
# =============================================================================
cat("\n--- Plotting linear model results ---\n")
# ── Plot A: OLS R² by predictor set ──────────────────────────────────────────
pA <- ggplot(lm_master, aes(x = reorder(PredictorSet, R2), y = R2, fill = Group)) +
geom_col(position = "dodge", alpha = 0.85) +
geom_text(aes(label = R2), position = position_dodge(width = 0.9),
hjust = -0.1, size = 2.6, fontface = "bold") +
facet_wrap(~Target, ncol = 1) +
coord_flip() +
scale_fill_manual(values = c(G1_Rhythmic = "#4e9af1", G2_Classical = "#e85d04", G3_HardRock = "#06d6a0")) +
ylim(0, 1.1) +
labs(title = "OLS Linear Regression — R² by Predictor Set",
subtitle = "Each bar = one genre group; sets ordered by R²",
x = NULL, y = "Test R²") +
theme_bw(base_size = 12) + theme(legend.position = "bottom")
ggsave("plots/LM_A_ols_predictor_r2.png", pA, width = 12, height = 9, dpi = 150)
# ── Plot B: OLS R² progression M1 → M5 ───────────────────────────────────────
pB <- lm_master %>%
mutate(SetNum = as.integer(gsub("M(\\d+):.*", "\\1", PredictorSet))) %>%
ggplot(aes(x = SetNum, y = R2, color = Group, group = Group)) +
geom_line(linewidth = 1.2) + geom_point(size = 3.5) +
facet_wrap(~Target, ncol = 1) +
scale_x_continuous(breaks = 1:5,
labels = c("M1\n(1 pred)", "M2\n(3 pred)", "M3\n(3 pred)", "M4\n(8 pred)", "M5\n(10 pred)")) +
scale_color_manual(values = c(G1_Rhythmic = "#4e9af1", G2_Classical = "#e85d04", G3_HardRock = "#06d6a0")) +
labs(title = "OLS — R² as More Predictors Are Added",
subtitle = "Does adding features consistently help?",
x = "Predictor Set (simple to complex)", y = "Test R²") +
theme_bw(base_size = 13)
ggsave("plots/LM_B_ols_r2_progression.png", pB, width = 10, height = 9, dpi = 150)
# ── Plot C: ElasticNet alpha path (lambda.min) ────────────────────────────────
pC <- en_master %>%
filter(Lambda_rule == "lambda.min") %>%
ggplot(aes(x = Alpha, y = R2, color = Group, group = Group)) +
geom_line(linewidth = 1.2) + geom_point(size = 3) +
facet_wrap(~Target, ncol = 1) +
scale_color_manual(values = c(G1_Rhythmic = "#4e9af1", G2_Classical = "#e85d04", G3_HardRock = "#06d6a0")) +
scale_x_continuous(breaks = seq(0, 1, 0.1),
labels = c("0\n(Ridge)", ".1", ".2", ".3", ".4", ".5", ".6", ".7", ".8", ".9", "1\n(Lasso)")) +
labs(title = "ElasticNet — R² Across the Full Alpha Path",
subtitle = "Left = Ridge | Right = Lasso | λ chosen by 5-fold CV at each α",
x = "Alpha (mixing parameter)", y = "Test R²") +
theme_bw(base_size = 13)
ggsave("plots/LM_C_elasticnet_alpha_path.png", pC, width = 11, height = 9, dpi = 150)
# ── Plot D: lambda.min vs lambda.1se comparison ───────────────────────────────
pD <- en_master %>%
ggplot(aes(x = Alpha, y = R2, color = Group,
linetype = Lambda_rule, group = interaction(Group, Lambda_rule))) +
geom_line(linewidth = 1) + geom_point(size = 2.5) +
facet_wrap(~Target, ncol = 1) +
scale_color_manual(values = c(G1_Rhythmic = "#4e9af1", G2_Classical = "#e85d04", G3_HardRock = "#06d6a0")) +
scale_linetype_manual(values = c("lambda.min" = "solid", "lambda.1se" = "dashed"), name = "Lambda rule") +
labs(title = "ElasticNet — lambda.min vs lambda.1se Across Alpha",
subtitle = "Solid = minimum CV error | Dashed = 1-SE rule (more regularisation)",
x = "Alpha", y = "Test R²") +
theme_bw(base_size = 12) + theme(legend.position = "bottom")
ggsave("plots/LM_D_elasticnet_lambda_comparison.png", pD, width = 11, height = 9, dpi = 150)
# ── Plot E: Best OLS vs Best ElasticNet side-by-side ─────────────────────────
best_en <- en_master %>%
filter(Lambda_rule == "lambda.min") %>%
group_by(Group, Target) %>% slice_max(R2, n = 1) %>% ungroup() %>%
mutate(Model = paste0("ElasticNet (best α=", Alpha, ")"))
best_ols <- lm_master %>%
group_by(Group, Target) %>% slice_max(R2, n = 1) %>% ungroup() %>%
mutate(Model = "OLS (best set)")
compare_df <- bind_rows(
best_ols %>% select(Group, Target, Model, R2),
best_en  %>% select(Group, Target, Model, R2)
)
pE <- ggplot(compare_df, aes(x = Group, y = R2, fill = Model)) +
geom_col(position = "dodge", alpha = 0.85, width = 0.65) +
geom_text(aes(label = R2), position = position_dodge(width = 0.65),
vjust = -0.4, size = 3.5, fontface = "bold") +
facet_wrap(~Target, ncol = 1) +
scale_fill_manual(values = c("OLS (best set)" = "#4e9af1",
"ElasticNet (best α=0)" = "#e85d04",
"ElasticNet (best α=0.1)" = "#e85d04",
"ElasticNet (best α=0.2)" = "#e85d04",
"ElasticNet (best α=0.3)" = "#e85d04",
"ElasticNet (best α=0.4)" = "#e85d04",
"ElasticNet (best α=0.5)" = "#e85d04",
"ElasticNet (best α=0.6)" = "#e85d04",
"ElasticNet (best α=0.7)" = "#e85d04",
"ElasticNet (best α=0.8)" = "#e85d04",
"ElasticNet (best α=0.9)" = "#e85d04",
"ElasticNet (best α=1)" = "#e85d04")) +
ylim(0, 1.1) +
labs(title = "Best OLS vs Best ElasticNet per Group",
subtitle = "OLS = best predictor set | ElasticNet = best α via 5-fold CV",
x = NULL, y = "Test R²") +
theme_bw(base_size = 13) + theme(legend.position = "bottom")
ggsave("plots/LM_E_ols_vs_elasticnet.png", pE, width = 10, height = 9, dpi = 150)
# ── Plot F: Optimal lambda at each alpha (regularisation path) ────────────────
pF <- en_master %>%
filter(Lambda_rule == "lambda.min") %>%
ggplot(aes(x = Alpha, y = Best_lambda, color = Group,
linetype = Target, group = interaction(Group, Target))) +
geom_line(linewidth = 1) + geom_point(size = 2.5) +
scale_color_manual(values = c(G1_Rhythmic = "#4e9af1", G2_Classical = "#e85d04", G3_HardRock = "#06d6a0")) +
scale_linetype_manual(values = c(valence = "solid", energy = "dashed")) +
scale_y_log10() +
labs(title = "ElasticNet — Optimal Lambda at Each Alpha",
subtitle = "How much regularisation does CV prefer as sparsity increases?",
x = "Alpha", y = "Best Lambda (log scale)") +
theme_bw(base_size = 13) + theme(legend.position = "bottom")
ggsave("plots/LM_F_elasticnet_lambda_path.png", pF, width = 10, height = 6, dpi = 150)
# =============================================================================
#  FINAL SUMMARY — LINEAR MODELS
# =============================================================================
cat("\n\n============================================================\n")
cat(" LINEAR MODELS — FINAL SUMMARY\n")
cat("============================================================\n\n")
cat("--- Best OLS predictor set per Group x Target ---\n")
print(as.data.frame(
lm_master %>% group_by(Group, Target) %>% slice_max(R2, n = 1) %>%
select(Group, Target, PredictorSet, N_predictors, RMSE, R2)
))
cat("\n--- Best ElasticNet config per Group x Target (lambda.min) ---\n")
print(as.data.frame(
en_master %>% filter(Lambda_rule == "lambda.min") %>%
group_by(Group, Target) %>% slice_max(R2, n = 1) %>%
select(Group, Target, Alpha, Best_lambda, RMSE, R2)
))
